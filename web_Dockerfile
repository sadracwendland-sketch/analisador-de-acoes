FROM python:3.11-slim

# Instalar curl para o healthcheck diretamente (mais estável)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copiar requirements unificados (na raiz)
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && pip install --no-cache-dir -r requirements.txt

# Copiar o código do backend (agora na raiz do repositório)
COPY app ./app

# Copiar o Streamlit app e a pasta static (agora na raiz do repositório)
COPY streamlit_app.py .
COPY static ./static

EXPOSE 8501

CMD ["streamlit", "run", "streamlit_app.py", "--server.port=8501", "--server.address=0.0.0.0"]
